// AI Development tab layout
// Designed to be opened as a new tab: zellij action new-tab --layout ai-dev
// Structure:
//   - Top pane: Copilot CLI (focused, full width)
//   - Bottom pane: Shell (for tests, output)
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab focus=true {
        pane split_direction="vertical" {
            pane name="copilot" size="65%" command="copilot"
            pane name="shell" size="35%"
        }
    }
}
