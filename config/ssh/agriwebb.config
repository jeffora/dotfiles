Host *
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# Host aw-showcase
#     ProxyJump aw-syd1
#     HostName 10.85.2.174
#     User agriwebb

# Host aw-buildkite
#     HostName 115.64.50.130
#     Port 9001
#     User buildkite

# internal access

Match Host aw-syd1 localnetwork 10.85.0.0/22
    ProxyJump none
    HostName 10.85.3.161
    Port 22

Match Host aw-syd2 localnetwork 10.85.0.0/22
    HostName 10.85.0.254
    Port 22

Match Host aw-syd3 localnetwork 10.85.0.0/22
    HostName 10.85.0.212
    Port 22

# external access 

Host aw-syd1
    HostName 193.114.139.238
    Port 9001
    User agriwebb
    LocalForward 5901 localhost:5900
    LocalForward 33061 localhost:33060
    SetEnv TERM=xterm-256color

Host aw-syd2
    HostName 10.85.2.22
    ProxyJump aw-syd1
    User agriwebb
    LocalForward 5902 localhost:5900
    LocalForward 33062 localhost:33060
    SetEnv TERM=xterm-256color

Host aw-syd3
    HostName 10.85.2.25
    ProxyJump aw-syd1
    User agriwebb
    LocalForward 5903 localhost:5900
    LocalForward 33063 localhost:33060
    SetEnv TERM=xterm-256color
