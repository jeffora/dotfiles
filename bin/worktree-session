#!/usr/bin/env bash
# Create a git worktree and launch a Zellij session for it.
# Usage: worktree-session <branch-name> [base-branch]
set -euo pipefail

branch="${1:?Usage: worktree-session <branch-name> [base-branch]}"
base="${2:-HEAD}"

# Resolve the repo root and create worktree as sibling directory
repo_root="$(git rev-parse --show-toplevel)"
repo_name="$(basename "$repo_root")"
worktree_dir="$(dirname "$repo_root")/${repo_name}-${branch}"

if [ -d "$worktree_dir" ]; then
  echo "Worktree already exists at $worktree_dir"
else
  git worktree add "$worktree_dir" -b "$branch" "$base"
  echo "Created worktree at $worktree_dir"
fi

session_name="${repo_name}-${branch}"

# Launch or attach to Zellij session
cd "$worktree_dir"
if zellij list-sessions 2>/dev/null | grep -q "^${session_name}"; then
  echo "Attaching to existing session: $session_name"
  zellij attach "$session_name"
else
  echo "Creating new session: $session_name"
  zellij --session "$session_name" --layout worktree
fi
