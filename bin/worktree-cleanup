#!/usr/bin/env bash
# Clean up a git worktree and its Zellij session.
# Usage: worktree-cleanup <branch-name>
set -euo pipefail

branch="${1:?Usage: worktree-cleanup <branch-name>}"

repo_root="$(git rev-parse --show-toplevel)"
repo_name="$(basename "$repo_root")"
worktree_dir="$(dirname "$repo_root")/${repo_name}-${branch}"
session_name="${repo_name}-${branch}"

# Kill Zellij session if it exists
if zellij list-sessions 2>/dev/null | grep -q "^${session_name}"; then
  zellij kill-session "$session_name"
  echo "Killed session: $session_name"
fi

# Remove worktree if it exists
if [ -d "$worktree_dir" ]; then
  git worktree remove "$worktree_dir"
  echo "Removed worktree: $worktree_dir"
else
  echo "No worktree found at $worktree_dir"
fi
